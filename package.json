{
  "name": "traq-bot-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "oxfmt --config oxfmt.config.ts \"*.config.ts\" config-env.d.ts package.json tsconfig.json \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "yarn format --check",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint --config eslint.config.ts src --max-warnings=0",
    "lint:fix": "eslint --config eslint.config.ts --fix src"
  },
  "dependencies": {
    "@quasar/extras": "2.0.1",
    "@traptitech/traq": "3.28.2-1",
    "github-markdown-css": "5.9.0",
    "pinia": "3.0.4",
    "quasar": "2.20.1",
    "vue": "3.5.39",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@quasar/vite-plugin": "1.12.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.6.0",
    "eslint-plugin-vue": "10.9.2",
    "jiti": "^2.7.0",
    "markdown-it": "14.2.0",
    "markdown-it-mark": "4.0.0",
    "oxfmt": "^0.56.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.3",
    "vite-plugin-markdown": "2.2.0",
    "vitest": "4.1.9",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "3.3.5"
  },
  "resolutions": {
    "markdown-it@npm:^12.0.0": "npm:14.2.0"
  },
  "packageManager": "yarn@4.17.0"
}
