@import './quasar.variables.styl'

.q-dialog.fullscreen .q-card__section {
  max-height: 70vh;
}

.create-page,
.create-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.create-page > h6 {
  margin: 0;
}

.create-actions {
  display: flex;
  justify-content: flex-end;
}

.scope-field {
  border: 1px solid rgba(0, 0, 0, .24);
  border-radius: 4px;
  margin: 0;
  padding: 8px 12px 6px;
}

.scope-field legend {
  color: rgba(0, 0, 0, .6);
  font-size: 12px;
  padding: 0 4px;
}

.scope-field__hint {
  color: rgba(0, 0, 0, .54);
  font-size: 12px;
  line-height: 1.5;
  margin-top: 4px;
}

.body--dark .scope-field {
  border-color: rgba(255, 255, 255, .48);
}

.body--dark .scope-field legend,
.body--dark .scope-field__hint {
  color: rgba(255, 255, 255, .7);
}

.app-warning-banner {
  background: #ffffff;
  color: #1f2328;
  border: 1px solid #d0d7de;
}

.body--dark .app-warning-banner {
  background: #1d1d1d;
  color: #e6edf3;
  border-color: #30363d;
}

.body--dark .app-warning-banner a {
  color: #79c0ff;
}
