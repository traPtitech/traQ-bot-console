@import './quasar.variables.styl'

.q-dialog.fullscreen .q-card__section {
  max-height: 70vh;
}

.create-page,
.create-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.create-page > h6 {
  margin: 0;
}

.create-actions {
  display: flex;
  justify-content: flex-end;
}

.app-warning-banner {
  background: #ffffff;
  color: #1f2328;
  border: 1px solid #d0d7de;
}

.body--dark .app-warning-banner {
  background: #1d1d1d;
  color: #e6edf3;
  border-color: #30363d;
}

.body--dark .app-warning-banner a {
  color: #79c0ff;
}
